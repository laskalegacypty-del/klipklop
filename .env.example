# Supabase (client) — used by the app
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Supabase (server-side only) — used by api/share/* routes
# NEVER expose to the browser (do not prefix with VITE_).
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional public app URL for share links when Host header is unavailable locally
PUBLIC_APP_URL=http://localhost:5173

# Cloudflare Workers AI (server-side only) — used by api/rules/chat.js
# Set these in Vercel Project Settings > Environment Variables,
# and locally in a .env file (gitignored) when running `vercel dev`.
# NEVER expose CF_API_TOKEN to the browser (do not prefix with VITE_).
CF_ACCOUNT_ID=8b60730ec10ba7eb7e85d214fa2505c2
CF_API_TOKEN=
# Optional override; defaults to @cf/meta/llama-3.3-70b-instruct-fp8-fast
CF_MODEL=
